{
  "color": {
    "bg":             { "$value": "#0f0f0f",  "$type": "color", "$description": "Page background" },
    "surface":        { "$value": "#1a1a1a",  "$type": "color", "$description": "Card / panel background" },
    "surfaceHover":   { "$value": "#222222",  "$type": "color", "$description": "Hovered surface" },
    "surfaceRaised":  { "$value": "#242424",  "$type": "color", "$description": "Elevated surface (dropdowns, tooltips)" },
    "border":         { "$value": "#2e2e2e",  "$type": "color", "$description": "Default border" },
    "borderFocus":    { "$value": "#4a5a75",  "$type": "color", "$description": "Focused input border" },
    "text":           { "$value": "#e8e8e8",  "$type": "color", "$description": "Primary text" },
    "textMuted":      { "$value": "#aaaaaa",  "$type": "color", "$description": "Secondary / muted text" },
    "textDisabled":   { "$value": "#555555",  "$type": "color", "$description": "Disabled / placeholder text" },
    "accent":         { "$value": "#ff0000",  "$type": "color", "$description": "Brand accent — YouTube red" },
    "accentHover":    { "$value": "#cc0000",  "$type": "color", "$description": "Accent hover state" },
    "success":        { "$value": "#2d7a2d",  "$type": "color" },
    "successBg":      { "$value": "#e6f4e6",  "$type": "color" },
    "warning":        { "$value": "#a05c00",  "$type": "color" },
    "warningBg":      { "$value": "#fff3e0",  "$type": "color" },
    "error":          { "$value": "#b00020",  "$type": "color" },
    "errorBg":        { "$value": "#fce4e4",  "$type": "color" },
    "info":               { "$value": "#9fc1ff",  "$type": "color" },
    "sentimentPositive":  { "$value": "#4ade80",  "$type": "color" },
    "sentimentNegative":  { "$value": "#f87171",  "$type": "color" }
  },
  "fontSize": {
    "sm":   { "$value": "12px",  "$type": "dimension", "$description": "Timestamps, badges, captions, hints" },
    "base": { "$value": "14px",  "$type": "dimension", "$description": "Body copy, inputs, buttons, labels" },
    "lg":   { "$value": "17px",  "$type": "dimension", "$description": "Panel / modal headings" },
    "xl":   { "$value": "20px",  "$type": "dimension", "$description": "Page / extension title" }
  },
  "fontWeight": {
    "normal":   { "$value": 400, "$type": "number" },
    "semibold": { "$value": 600, "$type": "number" },
    "bold":     { "$value": 700, "$type": "number" }
  },
  "lineHeight": {
    "tight":   { "$value": 1.25, "$type": "number", "$description": "Headings and compact UI" },
    "base":    { "$value": 1.45, "$type": "number", "$description": "Default body copy and interface text" },
    "relaxed": { "$value": 1.6,  "$type": "number", "$description": "Long-form readable content" }
  },
  "textStyle": {
    "caption": {
      "$type": "typography",
      "$description": "Timestamps, badges, inline metadata",
      "fontSize":   { "$value": "{fontSize.sm}" },
      "fontWeight": { "$value": "{fontWeight.normal}" },
      "lineHeight": { "$value": "{lineHeight.base}" }
    },
    "hint": {
      "$type": "typography",
      "$description": "Form hints, helper text, muted secondary content",
      "fontSize":   { "$value": "{fontSize.sm}" },
      "fontWeight": { "$value": "{fontWeight.normal}" },
      "lineHeight": { "$value": "{lineHeight.base}" }
    },
    "body": {
      "$type": "typography",
      "$description": "Default body text, descriptions, inputs",
      "fontSize":   { "$value": "{fontSize.base}" },
      "fontWeight": { "$value": "{fontWeight.normal}" },
      "lineHeight": { "$value": "{lineHeight.base}" }
    },
    "label": {
      "$type": "typography",
      "$description": "Form labels, section headings, tab text",
      "fontSize":   { "$value": "{fontSize.base}" },
      "fontWeight": { "$value": "{fontWeight.semibold}" },
      "lineHeight": { "$value": "{lineHeight.tight}" }
    },
    "ui": {
      "$type": "typography",
      "$description": "Interactive elements — buttons, menu items",
      "fontSize":   { "$value": "{fontSize.base}" },
      "fontWeight": { "$value": "{fontWeight.semibold}" },
      "lineHeight": { "$value": "{lineHeight.tight}" }
    },
    "heading": {
      "$type": "typography",
      "$description": "Panel headings, modal titles",
      "fontSize":   { "$value": "{fontSize.lg}" },
      "fontWeight": { "$value": "{fontWeight.semibold}" },
      "lineHeight": { "$value": "{lineHeight.tight}" }
    },
    "title": {
      "$type": "typography",
      "$description": "Page / extension title",
      "fontSize":   { "$value": "{fontSize.xl}" },
      "fontWeight": { "$value": "{fontWeight.bold}" },
      "lineHeight": { "$value": "{lineHeight.tight}" }
    }
  },
  "spacing": {
    "1": { "$value": "4px",  "$type": "dimension" },
    "2": { "$value": "8px",  "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "4px",    "$type": "dimension" },
    "base": { "$value": "8px",    "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 2px 8px rgba(0,0,0,0.3)",  "$type": "shadow" },
    "md": { "$value": "0 4px 16px rgba(0,0,0,0.5)", "$type": "shadow" }
  }
}
